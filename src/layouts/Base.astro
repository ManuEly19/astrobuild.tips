---

import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

export interface Props {
    title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<BaseHead title="AstroTips" description="My First Page with Astro"/>
<body class="h-screen bg-slate-900 text-slate-400 ">
    <div class="flex-block max-w-xl p-4 md:p-8 mx-auto mt-4">
        <div class="bg-white shadow rounded-lg p-4">
            <slot />
        </div>
    </div>
</body>
</html>