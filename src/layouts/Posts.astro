---
const {
	content: { title, date, description, image, tags },
} = Astro.props
---

<section>
	<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:items-center md:gap-8">
			<div>
				<div class="max-w-prose md:max-w-none">
					<h2 class="text-2xl font-semibold text-gray-900 sm:text-3xl">
						{title}
					</h2>
					<samp class="flex flex-col sm:gap-y-2 md:flex-row md:items-center md:gap-y-0 md:divide-x md:divide-textColor">
						<time datetime={date} class="block text-xs text-gray-500">
							{date}
						</time>
                            {tags.map((item: string) => (
                                <span
                                    class="whitespace-nowrap rounded-full bg-purple-100 px-2.5 py-0.5 text-xs text-purple-600"
                                >
                                    {item}
                                </span>
                            ))}
					</samp>

					<p class="mt-4 text-pretty text-gray-700">
						{description}
					</p>
				</div>
			</div>

			<div>
				<img alt={title} src={image} class="rounded" alt="" />
			</div>
		</div>
	</div>
	<slot />
</section>
